# Local development only — copy to `.env` and customize.
# Never commit real secrets. Docker Compose defaults below are intentionally weak.

NODE_ENV=development
LOG_LEVEL=info

# API
API_HOST=0.0.0.0
API_PORT=3000
# Use a long random value before any shared/staging/production deploy
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=1h

# Database
DATABASE_URL=postgresql://atlas:atlas@localhost:5432/atlas?schema=public

# Redis / BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MinIO / S3 (local Compose credentials — replace in real environments)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=atlasminio
S3_SECRET_ACCESS_KEY=atlasminio
S3_BUCKET=atlas-documents
S3_FORCE_PATH_STYLE=true

# Worker
INGESTION_QUEUE_NAME=ingestion
INGESTION_DLQ_NAME=ingestion-dlq
WORKER_CONCURRENCY=2

# Embeddings (Ollama on the host machine)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:latest
EMBEDDING_DIMENSIONS=4096
EMBEDDING_BATCH_SIZE=16

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=atlas_chunks

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Observability
OTEL_ENABLED=false
OTEL_SERVICE_NAME=atlas
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
