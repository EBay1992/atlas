{
  "name": "atlas",
  "version": "0.1.0",
  "private": true,
  "description": "Atlas — enterprise knowledge platform",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "pnpm db:generate",
    "build": "pnpm -r run typecheck && pnpm -r run build",
    "dev:api": "pnpm --filter @atlas/api dev",
    "dev:worker": "pnpm --filter @atlas/worker dev",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run typecheck",
    "db:generate": "pnpm --filter @atlas/infra db:generate",
    "db:migrate": "pnpm --filter @atlas/infra db:migrate",
    "db:seed": "pnpm --filter @atlas/infra db:seed",
    "seed:docs": "bash scripts/seed-polysemy-docs.sh",
    "aspire:restore": "cd apphost && aspire restore",
    "aspire:run": "cd apphost && aspire run",
    "typecheck": "pnpm -r run typecheck"
  }
}
