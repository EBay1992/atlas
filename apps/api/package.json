{
  "name": "@atlas/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.unit.config.ts --passWithNoTests",
    "test:integration": "vitest run --config vitest.config.ts src/ingestion.integration.test.ts",
    "lint": "echo \"no lint configured\""
  },
  "dependencies": {
    "@atlas/config": "workspace:*",
    "@atlas/domain": "workspace:*",
    "@atlas/infra": "workspace:*",
    "@atlas/observability": "workspace:*",
    "@atlas/test-utils": "workspace:^",
    "@fastify/multipart": "^9.0.1",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "close-with-grace": "^2.1.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
